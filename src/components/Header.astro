---
import { site } from '~/utils/config';
import Hr from './Hr.astro';
import Link from './Link.astro';
import LogoDark from '~/assets/logo-dark.svg';
import LogoLight from '~/assets/logo-light.svg';

export interface Props {
	activeNav?: 'posts' | 'tags' | 'about' | 'search';
}

const { activeNav } = Astro.props;
---

<header>
  <a
    class="absolute -top-full left-16 z-50 bg-accent px-3 py-2 text-inverted transition-all focus:top-4"
    id="skip-to-content"
    href="#main-content"
  >
    Skip to content
  </a>
  <div class="mx-auto flex max-w-4xl flex-col items-center sm:flex-row">
    <div class="relative w-full">
      <nav
        id="nav-menu"
        class="relative order-2 mt-10 flex w-full flex-col items-center sm:order-1 sm:mt-6 sm:grid sm:grid-cols-3 sm:justify-items-center sm:py-0"
      >
        <a href="/" class="block text-xl font-semibold sm:hidden">
          <span class="block sm:hidden">{site.title}</span>
        </a>
        <button
          class="hamburger-menu focus-outline"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="menu-icon"
          >
            <line x1="7" y1="12" x2="21" y2="12" class="line"></line>
            <line x1="3" y1="6" x2="21" y2="6" class="line"></line>
            <line x1="12" y1="18" x2="21" y2="18" class="line"></line>
            <line x1="18" y1="6" x2="6" y2="18" class="close"></line>
            <line x1="6" y1="6" x2="18" y2="18" class="close"></line>
          </svg>
        </button>
        <ul id="menu-items" class="hidden sm:flex">
          <li>
            <a
              data-test-id="nav-link-blog"
              href="/posts"
              class={activeNav === 'posts' ? 'active' : ''}
            >
              Posts
            </a>
          </li>
          <li>
            <a
              data-test-id="nav-link-tags"
              href="/tags"
              class={activeNav === 'tags' ? 'active' : ''}
            >
              Tags
            </a>
          </li>
          <li>
            <a
              data-test-id="nav-link-about"
              href="/about"
              class={activeNav === 'about' ? 'active' : ''}
            >
              About
            </a>
          </li>
          <li class="col-span-1! sm:hidden!">
            <Link
              href="/search"
              className={`focus-outline p-3 sm:p-1 ${
                activeNav === 'search' ? 'active' : ''
              } flex items-center`}
              aria-label="search"
              title="Search"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="scale-125 sm:scale-100"
                ><path
                  d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
                ></path>
              </svg>
            </Link>
          </li>

          {
            site.lightAndDarkMode ? (
              <li class="col-span-1! sm:hidden!">
                <button
                  id="theme-btn"
                  class="focus-outline p-3 sm:p-1"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                  data-test-id="darkmode-button"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    id="moon-svg"
                    class="block scale-125 hover:rotate-12 sm:scale-100"
                  >
                    <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059z" />
                  </svg>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    id="sun-svg"
                    class="hidden scale-125 hover:rotate-12 sm:scale-100"
                  >
                    <path d="M6.993 12c0 2.761 2.246 5.007 5.007 5.007s5.007-2.246 5.007-5.007S14.761 6.993 12 6.993 6.993 9.239 6.993 12zM12 8.993c1.658 0 3.007 1.349 3.007 3.007S13.658 15.007 12 15.007 8.993 13.658 8.993 12 10.342 8.993 12 8.993zM10.998 19h2v3h-2zm0-17h2v3h-2zm-9 9h3v2h-3zm17 0h3v2h-3zM4.219 18.363l2.12-2.122 1.415 1.414-2.12 2.122zM16.24 6.344l2.122-2.122 1.414 1.414-2.122 2.122zM6.342 7.759 4.22 5.637l1.415-1.414 2.12 2.122zm13.434 10.605-1.414 1.414-2.122-2.122 1.414-1.414z" />
                  </svg>
                </button>
              </li>
            ) : null
          }
        </ul>

        <a
          href="/"
          class="z-5 relative order-1 hidden py-1 text-xl font-semibold sm:static sm:order-2 sm:block sm:text-2xl"
        >
          <span class="hidden sm:block">
            <img
              class="hidden dark:block"
              src={LogoDark.src}
              alt={site.title}
              width={108}
              height={108}
            />
            <img
              class="block dark:hidden"
              src={LogoLight.src}
              alt={site.title}
              width={108}
              height={108}
            />
          </span>
          <span class="block sm:hidden">{site.title}</span>
        </a>
        <div
          class="order-3 hidden h-full w-full justify-center space-x-4 sm:flex"
          id="menu-buttons"
        >
          <Link
            href="/search"
            className={`focus-outline p-3 sm:p-1 ${
              activeNav === 'search' ? 'active' : ''
            } flex items-center`}
            aria-label="search"
            title="Search"
            dataTestId="nav-link-search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="scale-125 sm:scale-100"
              ><path
                d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
              ></path>
            </svg>
          </Link>

          {
            site.lightAndDarkMode ? (
              <button
                id="theme-btn2"
                class="focus-outline p-3 sm:p-1"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
                data-test-id="darkmode-button"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="block scale-125 hover:rotate-12 dark:hidden sm:scale-100"
                >
                  <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059z" />
                </svg>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  id="sun-svg"
                  class="hidden scale-125 hover:rotate-12 dark:block sm:scale-100"
                >
                  <path d="M6.993 12c0 2.761 2.246 5.007 5.007 5.007s5.007-2.246 5.007-5.007S14.761 6.993 12 6.993 6.993 9.239 6.993 12zM12 8.993c1.658 0 3.007 1.349 3.007 3.007S13.658 15.007 12 15.007 8.993 13.658 8.993 12 10.342 8.993 12 8.993zM10.998 19h2v3h-2zm0-17h2v3h-2zm-9 9h3v2h-3zm17 0h3v2h-3zM4.219 18.363l2.12-2.122 1.415 1.414-2.12 2.122zM16.24 6.344l2.122-2.122 1.414 1.414-2.122 2.122zM6.342 7.759 4.22 5.637l1.415-1.414 2.12 2.122zm13.434 10.605-1.414 1.414-2.122-2.122 1.414-1.414z" />
                </svg>
              </button>
            ) : null
          }
        </div>
        <Hr
          className="absolute top-[98px] hidden w-screen px-4 sm:block lg:w-full"
          lineColor="border-accent"
        />
      </nav>
    </div>
  </div>
  <Hr className="block sm:hidden" />
</header>

<style>
  #skip-to-content {
    position: absolute;
    top: -100%;
    left: 4rem;
    z-index: 50;
    background-color: rgb(var(--color-accent-rgb));
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    color: rgb(var(--color-fill-rgb));
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }
  #skip-to-content:focus {
    top: 1rem;
  }
  .nav-container {
    margin-left: auto;
    margin-right: auto;
    display: flex;
    max-width: 56rem;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
  }
  @media (min-width: 640px) {
    .nav-container {
      flex-direction: row;
    }
  }
  .top-nav-wrap {
    position: relative;
    display: flex;
    width: 100%;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1rem;
  }
  @media (min-width: 640px) {
    .top-nav-wrap {
      align-items: center;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }
  }
  .logo {
    position: absolute;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 600;
  }
  @media (min-width: 640px) {
    .logo {
      position: static;
      font-size: 1.5rem;
      line-height: 2rem;
    }
  }
  .hamburger-menu {
    margin-top: -2.25rem;
    align-self: flex-end;
    padding: 0.5rem;
    padding-bottom: 1rem;
    padding-right: 1rem;
  }
  @media (min-width: 640px) {
    .hamburger-menu {
      display: none;
    }
  }
  .hamburger-menu svg {
    height: 1.5rem;
    width: 1.5rem;
    scale: 1.25;
    fill: rgb(var(--color-text-base));
  }
  nav ul {
    margin-top: 1rem;
    width: 11rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    nav ul {
      margin-left: 0;
      margin-top: 0;
      display: flex;
      width: auto;
      column-gap: 1.25rem;
      row-gap: 0;
    }
  }
  nav ul li {
    grid-column: span 2 / span 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  nav ul li a {
    width: 100%;
    padding-left: 1rem;
    padding-right: 1rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    text-align: center;
    font-weight: 500;
  }
  nav ul li a:hover {
    color: rgb(var(--color-accent-rgb));
  }
  @media (min-width: 640px) {
    nav ul li a {
      margin-top: 0;
      margin-bottom: 0;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
      padding-top: 0.25rem;
      padding-bottom: 0.25rem;
    }
  }
  nav ul li:nth-last-child(2) a {
    width: auto;
  }
  nav a.active {
    color: rgb(var(--color-accent-rgb));
    text-decoration-line: underline;
    text-decoration-style: wavy;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  nav a.active svg {
    fill: rgb(var(--color-accent-rgb));
  }
  .menu-icon line {
    transition-property: opacity;
    transition-duration: 75ms;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  .menu-icon .close {
    opacity: 0;
  }
  .menu-icon.is-active .line {
    opacity: 0;
  }
  .menu-icon.is-active .close {
    opacity: 1;
  }
  svg {
    height: 1.5rem;
    width: 1.5rem;
    fill: rgb(var(--color-text-base));
  }
  :is(:where(.group):hover *) svg {
    fill: rgb(var(--color-accent-rgb));
  }
</style>

<script>
  function toggleNav() {
    // Toggle menu
    const menuBtn = document.querySelector('.hamburger-menu');
    const menuIcon = document.querySelector('.menu-icon');
    const menuItems = document.querySelector('#menu-items');

    menuBtn?.addEventListener('click', () => {
      const menuExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuIcon?.classList.toggle('is-active');
      menuBtn.setAttribute('aria-expanded', menuExpanded ? 'false' : 'true');
      menuBtn.setAttribute(
        'aria-label',
        menuExpanded ? 'Open Menu' : 'Close Menu',
      );
      menuItems?.classList.remove(menuExpanded ? 'grid' : 'hidden');
      menuItems?.classList.add(menuExpanded ? 'hidden' : 'grid');
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener('astro:after-swap', toggleNav);
</script>
